---
const currentYear = new Date().getFullYear();
---

<footer class="footer">
  <div class="container">
    <div class="footer__content">
      <div class="footer__about">
        <h3>Living to Die</h3>
        <p class="footer__text">
          A powerful memoir of hope, justice, and one woman's fight for patients' rights.
        </p>
      </div>

      <div class="footer__links">
        <h4>Quick Links</h4>
        <ul>
          <li><a href="/#summary">About the Book</a></li>
          <li><a href="/#author">About the Author</a></li>
          <li><a href="/resources">Resources</a></li>
          <li><a href="/contact">Contact</a></li>
        </ul>
      </div>

      <div class="footer__links">
        <h4>Connect</h4>
        <ul>
          <li><a href="/contact">Contact</a></li>
          <li><a href="/contact">Speaking Requests</a></li>
          <li><a href="/blog">Blog</a></li>
        </ul>
      </div>

      <div class="footer__newsletter">
        <h4>Stay Updated</h4>
        <p class="footer__text">Join our mailing list for book updates and events.</p>
        <form
          class="footer__form"
          id="newsletter-form"
          action="https://assets.mailerlite.com/jsonp/2188276/forms/181849541197170482/subscribe"
          method="POST"
        >
          <input type="hidden" name="ml-submit" value="1" />
          <input type="hidden" name="anticsrf" value="true" />
          <input
            type="email"
            name="fields[email]"
            placeholder="Your email"
            required
            autocomplete="email"
          />
          <button type="submit" class="btn btn--primary">Subscribe</button>
        </form>
        <p class="footer__success" id="newsletter-success">Thanks for subscribing!</p>
      </div>
    </div>

    <div class="footer__bottom">
      <p>&copy; {currentYear} Diane Melton. All rights reserved.</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-primary);
    color: white;
    padding: 3rem 0 2rem;
    margin-top: 5rem;
  }

  .footer__content {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 2fr;
    gap: 3rem;
    margin-bottom: 2rem;
  }

  .footer h3, .footer h4 {
    color: white;
    margin-bottom: 1rem;
  }

  .footer__text {
    color: rgba(255, 255, 255, 0.7);
    margin-bottom: 1.5rem;
  }

  .footer__links ul {
    list-style: none;
    padding: 0;
  }

  .footer__links li {
    margin-bottom: 0.5rem;
  }

  .footer__links a {
    color: rgba(255, 255, 255, 0.7);
    transition: color var(--transition-fast);
  }

  .footer__links a:hover {
    color: var(--color-accent);
  }

  .footer__form {
    display: flex;
    gap: 0.5rem;
  }

  .footer__form input {
    flex: 1;
    padding: 0.5rem 1rem;
    border: none;
    border-radius: var(--radius-sm);
    background: rgba(255, 255, 255, 0.1);
    color: white;
  }

  .footer__form input::placeholder {
    color: rgba(255, 255, 255, 0.5);
  }

  .footer__form input:focus {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
    background: rgba(255, 255, 255, 0.15);
  }

  .footer__form button {
    padding: 0.5rem 1rem;
  }

  .footer__success {
    display: none;
    color: var(--color-accent);
    font-style: italic;
    margin-top: 0.75rem;
  }

  .footer__success.show {
    display: block;
  }

  .footer__form.hidden {
    display: none;
  }

  .footer__bottom {
    padding-top: 2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    text-align: center;
    color: rgba(255, 255, 255, 0.7);
  }

  @media (max-width: 768px) {
    .footer__content {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .footer__form {
      flex-direction: column;
    }
  }
</style>

<script>
  document.getElementById('newsletter-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.target as HTMLFormElement;
    const formData = new FormData(form);
    const successEl = document.getElementById('newsletter-success');

    try {
      // Submit to MailerLite using no-cors mode (their API doesn't support CORS)
      await fetch(form.action, {
        method: 'POST',
        body: formData,
        mode: 'no-cors'
      });

      // Hide form and show success message
      form.classList.add('hidden');
      successEl?.classList.add('show');
    } catch (error) {
      // Fallback: submit form normally if fetch fails
      form.submit();
    }
  });
</script>
