---
interface Props {
  minimal?: boolean;
}

const { minimal = false } = Astro.props;

const navItems = [
  { label: 'Home', href: '/' },
  { label: 'About', href: '/#author' },
  {
    label: 'Resources',
    href: '/resources',
    dropdown: [
      { label: 'Medical Advocacy', href: '/resources#medical-advocacy' },
      { label: 'Legal Resources', href: '/resources#legal-resources' },
      { label: 'Medical Research', href: '/resources#medical-research' },
      { label: 'Support Communities', href: '/resources#support-communities' },
    ]
  },
  { label: 'Contact', href: '/contact' },
];
---

<nav class:list={["nav", { "nav--transparent": true, "nav--minimal": minimal }]} id="navbar" data-minimal={minimal}>
  <div class="nav__container">
    <ul class="nav__menu" id="nav-menu">
      {navItems.map(item => (
        <li class={item.dropdown ? 'nav__item--dropdown' : ''}>
          <a href={item.href} class="nav__link">{item.label}</a>
          {item.dropdown && (
            <ul class="nav__dropdown">
              {item.dropdown.map(subItem => (
                <li>
                  <a href={subItem.href} class="nav__dropdown-link">{subItem.label}</a>
                </li>
              ))}
            </ul>
          )}
        </li>
      ))}
    </ul>

    <button class="nav__toggle" id="nav-toggle" aria-label="Menu">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>
</nav>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--color-border);
    transition: all var(--transition-base);
  }

  .nav--transparent {
    background: rgba(255, 255, 255, 0.9);
    backdrop-filter: blur(8px);
    border-bottom-color: transparent;
  }

  .nav.scrolled {
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(10px);
    border-bottom-color: var(--color-border);
    box-shadow: var(--shadow-md);
  }

  .nav.hidden {
    transform: translateY(-100%);
  }

  .nav__container {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.25rem 1.5rem;
    max-width: var(--container-max);
    margin: 0 auto;
  }

  .nav__menu {
    display: flex;
    list-style: none;
    gap: 2.5rem;
    margin: 0;
    padding: 0;
  }

  .nav__link {
    color: var(--color-text);
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 1.1rem;
    letter-spacing: 0.03em;
    transition: color var(--transition-fast);
    position: relative;
  }

  .nav__link::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0;
    height: 2px;
    background: var(--color-accent);
    transition: width var(--transition-base);
  }

  .nav__link:hover {
    color: var(--color-accent);
  }

  .nav__link:hover::after {
    width: 100%;
  }

  /* Dropdown styles */
  .nav__item--dropdown {
    position: relative;
  }

  .nav__dropdown {
    display: none;
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    background: white;
    list-style: none;
    padding: 0.75rem 0;
    min-width: 200px;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
    margin-top: 0.5rem;
    z-index: 1001;
  }

  .nav__dropdown::before {
    content: '';
    position: absolute;
    top: -8px;
    left: 50%;
    transform: translateX(-50%);
    border-left: 8px solid transparent;
    border-right: 8px solid transparent;
    border-bottom: 8px solid white;
  }

  .nav__item--dropdown:hover .nav__dropdown {
    display: block;
  }

  .nav__dropdown-link {
    display: block;
    padding: 0.5rem 1.25rem;
    color: var(--color-text);
    font-family: var(--font-display);
    font-size: 0.95rem;
    font-weight: 400;
    transition: all var(--transition-fast);
  }

  .nav__dropdown-link:hover {
    color: var(--color-accent);
    background: var(--color-beige);
  }

  .nav__toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.75rem;
  }

  .nav__toggle span {
    width: 26px;
    height: 2.5px;
    background: var(--color-primary);
    border-radius: 2px;
    transition: all var(--transition-fast);
  }

  /* Minimal mode - hamburger only at top, links when scrolled */
  .nav--minimal {
    background: transparent;
    backdrop-filter: none;
    border-bottom: none;
  }

  .nav--minimal .nav__container {
    justify-content: flex-end;
  }

  .nav--minimal .nav__menu {
    display: none;
  }

  .nav--minimal .nav__toggle {
    display: flex;
    background: rgba(255, 255, 255, 0.9);
    backdrop-filter: blur(8px);
    border-radius: 8px;
    padding: 0.75rem;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  }

  /* Hamburger dropdown when clicked (at top, before scroll) */
  .nav--minimal .nav__menu.active {
    display: flex;
    position: fixed;
    top: 70px;
    right: 1.5rem;
    left: auto;
    width: auto;
    min-width: 200px;
    background: white;
    flex-direction: column;
    padding: 1.5rem;
    gap: 1rem;
    border-radius: 12px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15);
  }

  /* When scrolled on desktop - show links, hide hamburger */
  .nav--minimal.scrolled {
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(12px);
    box-shadow: var(--shadow-md);
  }

  .nav--minimal.scrolled .nav__container {
    justify-content: center;
  }

  .nav--minimal.scrolled .nav__menu {
    display: flex;
  }

  .nav--minimal.scrolled .nav__toggle {
    display: none;
  }

  @media (max-width: 768px) {
    .nav__container {
      justify-content: flex-end;
    }

    .nav__menu {
      position: fixed;
      top: 60px;
      left: 0;
      right: 0;
      background: white;
      flex-direction: column;
      padding: 2rem;
      gap: 1rem;
      box-shadow: var(--shadow-lg);
      transform: translateY(-100%);
      opacity: 0;
      pointer-events: none;
      transition: all var(--transition-base);
    }

    .nav__menu.active {
      transform: translateY(0);
      opacity: 1;
      pointer-events: all;
    }

    /* Mobile dropdown - inline expand */
    .nav__dropdown {
      display: none;
      position: static;
      transform: none;
      background: transparent;
      box-shadow: none;
      padding: 0.5rem 0 0 1rem;
      margin-top: 0.5rem;
      min-width: auto;
      border-left: 2px solid var(--color-border);
    }

    .nav__dropdown::before {
      display: none;
    }

    .nav__item--dropdown.expanded .nav__dropdown {
      display: block;
    }

    .nav__dropdown-link {
      padding: 0.4rem 0.75rem;
      font-size: 0.9rem;
    }

    .nav__item--dropdown > .nav__link::after {
      content: '';
      display: inline-block;
      width: 6px;
      height: 6px;
      border-right: 2px solid currentColor;
      border-bottom: 2px solid currentColor;
      transform: rotate(45deg);
      margin-left: 0.5rem;
      transition: transform var(--transition-fast);
      position: static;
      background: none;
    }

    .nav__item--dropdown.expanded > .nav__link::after {
      transform: rotate(-135deg);
    }

    .nav__toggle {
      display: flex;
    }

    .nav__toggle.active span:nth-child(1) {
      transform: rotate(45deg) translate(5px, 5px);
    }

    .nav__toggle.active span:nth-child(2) {
      opacity: 0;
    }

    .nav__toggle.active span:nth-child(3) {
      transform: rotate(-45deg) translate(5px, -5px);
    }

    /* Minimal mode on mobile - always hamburger, even when scrolled */
    .nav--minimal .nav__container,
    .nav--minimal.scrolled .nav__container {
      justify-content: flex-end;
    }

    .nav--minimal .nav__menu,
    .nav--minimal.scrolled .nav__menu {
      display: none;
      position: fixed;
      top: 60px;
      left: 0;
      right: 0;
      background: white;
      flex-direction: column;
      padding: 2rem;
      gap: 1rem;
      box-shadow: var(--shadow-lg);
      transform: translateY(-100%);
      opacity: 0;
      pointer-events: none;
      transition: all var(--transition-base);
    }

    .nav--minimal .nav__menu.active,
    .nav--minimal.scrolled .nav__menu.active {
      display: flex;
      transform: translateY(0);
      opacity: 1;
      pointer-events: all;
    }

    .nav--minimal .nav__toggle,
    .nav--minimal.scrolled .nav__toggle {
      display: flex;
    }

    .nav--minimal.scrolled .nav__toggle {
      background: transparent;
      box-shadow: none;
    }
  }
</style>

<script>
  // Navigation scroll effect with hide/show
  let lastScroll = 0;
  const navbar = document.getElementById('navbar');
  const isMinimal = navbar?.dataset.minimal === 'true';
  const scrollThreshold = 5;

  window.addEventListener('scroll', () => {
    const currentScroll = window.pageYOffset;
    const scrollDelta = currentScroll - lastScroll;

    // Add background when scrolled past 50px
    if (currentScroll > 50) {
      navbar?.classList.add('scrolled');
      navbar?.classList.remove('nav--transparent');
    } else {
      navbar?.classList.remove('scrolled');
      navbar?.classList.add('nav--transparent');
    }

    // Hide/show based on scroll direction (only after initial 100px, and not in minimal mode)
    if (!isMinimal && currentScroll > 100) {
      if (scrollDelta > scrollThreshold) {
        navbar?.classList.add('hidden');
      } else if (scrollDelta < -scrollThreshold) {
        navbar?.classList.remove('hidden');
      }
    } else {
      navbar?.classList.remove('hidden');
    }

    lastScroll = currentScroll;
  });

  // Mobile menu toggle
  const navToggle = document.getElementById('nav-toggle');
  const navMenu = document.getElementById('nav-menu');

  navToggle?.addEventListener('click', () => {
    navToggle.classList.toggle('active');
    navMenu?.classList.toggle('active');
  });

  // Mobile dropdown toggle
  const isMobile = () => window.innerWidth <= 768;

  document.querySelectorAll('.nav__item--dropdown > .nav__link').forEach(link => {
    link.addEventListener('click', (e) => {
      if (isMobile()) {
        e.preventDefault();
        const parent = (e.target as HTMLElement).closest('.nav__item--dropdown');
        parent?.classList.toggle('expanded');
      }
    });
  });

  // Close mobile menu when clicking a link (but not dropdown parent)
  document.querySelectorAll('.nav__link').forEach(link => {
    link.addEventListener('click', (e) => {
      const parent = (e.target as HTMLElement).closest('.nav__item--dropdown');
      // Only close if it's not a dropdown parent on mobile, or if it's desktop
      if (!parent || !isMobile()) {
        navToggle?.classList.remove('active');
        navMenu?.classList.remove('active');
      }
    });
  });

  // Close mobile menu when clicking dropdown links
  document.querySelectorAll('.nav__dropdown-link').forEach(link => {
    link.addEventListener('click', () => {
      navToggle?.classList.remove('active');
      navMenu?.classList.remove('active');
      document.querySelectorAll('.nav__item--dropdown').forEach(item => {
        item.classList.remove('expanded');
      });
    });
  });

  // Close menu when clicking outside (for minimal mode dropdown)
  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    if (!target.closest('.nav__toggle') && !target.closest('.nav__menu')) {
      navToggle?.classList.remove('active');
      navMenu?.classList.remove('active');
    }
  });
</script>
