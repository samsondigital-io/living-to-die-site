---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

// Get latest blog posts
const allBlogPosts = await getCollection('blog');
const latestPosts = allBlogPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<BaseLayout title="Home">
  <!-- Hero Section -->
  <section class="hero">
    <div class="container hero__container">
      <div class="hero__content">
        <span class="hero__badge">Coming Spring 2024</span>
        <h1 class="hero__title">Living to Die</h1>
        <p class="hero__subtitle">
          A powerful memoir of faith, justice, and a mother's relentless fight against medical negligence that changed the conversation around women's healthcare.
        </p>
        <div class="hero__buttons">
          <a href="/preorder" class="btn btn--primary">Pre-Order Now</a>
          <a href="#about" class="btn btn--secondary">Learn More</a>
        </div>
      </div>
      <div class="hero__visual">
        <img src="https://picsum.photos/450/650?random=1" alt="Living to Die Book Cover" class="hero__image" />
      </div>
    </div>
  </section>

  <!-- Pre-order Section -->
  <section class="section section--contrast" id="preorder">
    <div class="container preorder">
      <div class="preorder__headline">
        <h2>Reserve Your Copy</h2>
        <p>
          Living to Die invites readers into the Sawicki family's eight-year odyssey through aggressive breast cancer, medical injustice, and the relentless pursuit of truth. Share this story with the caregivers, advocates, and believers in your life.
        </p>
      </div>
      <div class="preorder__links">
        <a class="btn btn--primary" href="#">Coming Soon</a>
        <a class="btn btn--secondary" href="#">Bulk & Institutional Orders</a>
      </div>
    </div>
  </section>

  <!-- Summary Section -->
  <section class="section" id="summary">
    <div class="container summary">
      <div class="summary__body">
        <h2>The Story at the Heart of Living to Die</h2>
        <p>
          On August 2, 2000, a routine mammogram failed to flag what Brenda Sawicki's instincts already knew: something was terribly wrong. By the time her cancer was finally diagnosed, it had advanced beyond the reach of easy answers. She refused to surrender. Drawing on deep wells of faith, entrepreneurship, and raw grit, Brenda waged a fight for her life and for accountability—challenging a medical system that overlooked her and holding power to account in the courts.
        </p>
        <p>
          Through Diane Melton's meticulous reporting and intimate storytelling, Living to Die chronicles Brenda's final years: the aggressive treatments, the urgent legal crusade against negligence, and the fierce love that kept a family whole. This memoir bears witness to the cost of institutional failure and to the incandescent strength of a woman determined to leave a legacy of justice.
        </p>
      </div>
      <aside class="summary__highlights">
        <h3>Key Themes</h3>
        <ul>
          <li>Patient advocacy and systemic accountability</li>
          <li>Motherhood, legacy, and preparing a family for goodbye</li>
          <li>Faith as anchor through grief and uncertainty</li>
        </ul>
      </aside>
    </div>
  </section>

  <!-- Book Structure -->
  <section class="section section--muted" id="structure">
    <div class="container structure">
      <div class="structure__card">
        <h3>Inside the Book</h3>
        <p>75+ chapters spanning diagnosis, trial preparation, courtroom testimony, and the reverberations that followed.</p>
      </div>
      <div class="structure__card">
        <h3>For Readers Who</h3>
        <p>Champion women's health, seek nuanced caregiving narratives, and believe in the power of legal reform.</p>
      </div>
      <div class="structure__card">
        <h3>Ideal For</h3>
        <p>Book clubs, hospital foundations, faith communities, advocacy organizations, and graduate ethics programs.</p>
      </div>
    </div>
  </section>

  <!-- Author Section -->
  <section class="section" id="author">
    <div class="container author">
      <div class="author__portrait">
        <img src="https://picsum.photos/420/420?random=2" alt="Diane Melton" />
      </div>
      <div class="author__bio">
        <h2>About the Author</h2>
        <p>
          Diane Melton's devotion to storytelling began in third grade when a teacher spotlighted her writing. She later earned a Master of Arts in Liberal Studies from Wesleyan University, concentrating in creative writing, and went on to teach writing and poetry at Central Connecticut State University.
        </p>
        <p>
          Her essays and narrative nonfiction have appeared in The New York Times, The Hartford Courant, Northeast Magazine, Seasons Magazine, and Latitudes. She was honored by the Connecticut Society of Professional Journalists for outstanding feature writing.
        </p>
        <p>
          Away from the page, Diane is an avid street photographer who loves welcoming friends around the table, walking, swimming, training at the gym, and escaping to the beach. Living to Die marks her debut nonfiction book, and she invites readers to join her on Brenda Sawicki's indelible journey.
        </p>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="section section--alt">
    <div class="container">
      <div class="section__header">
        <h2 class="section__title">Praise for Living to Die</h2>
      </div>

      <div class="testimonials-grid">
        <div class="testimonial-card">
          <p class="testimonial-card__quote">
            "An unflinching account of one family's fight for dignity. Melton's prose shimmers with both reverence and righteous anger."
          </p>
          <div class="testimonial-card__author">
            <div class="testimonial-card__avatar">SM</div>
            <div>
              <div class="testimonial-card__name">Sarah Mitchell</div>
              <div class="testimonial-card__title">Investigative Journalist, NYT</div>
            </div>
          </div>
        </div>

        <div class="testimonial-card">
          <p class="testimonial-card__quote">
            "Living to Die should be required reading for anyone in healthcare. It's as instructive as it is unforgettable."
          </p>
          <div class="testimonial-card__author">
            <div class="testimonial-card__avatar">DR</div>
            <div>
              <div class="testimonial-card__name">Dr. Rebecca Chen</div>
              <div class="testimonial-card__title">Author of "Patient Advocacy"</div>
            </div>
          </div>
        </div>

        <div class="testimonial-card">
          <p class="testimonial-card__quote">
            "A luminous testament to the power of faith and family in the face of systemic failure."
          </p>
          <div class="testimonial-card__author">
            <div class="testimonial-card__avatar">JW</div>
            <div>
              <div class="testimonial-card__name">Jennifer Walsh</div>
              <div class="testimonial-card__title">Founder, Women's Health Alliance</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Resources Preview -->
  <section class="section">
    <div class="container">
      <div class="section__header">
        <h2 class="section__title">Resources & Support</h2>
        <p class="section__subtitle">
          Organizations and information for those affected by medical negligence and seeking advocacy support.
        </p>
      </div>

      <div class="resources-preview">
        <div class="resource-preview-card">
          <div class="resource-preview__image">
            <img src="https://via.placeholder.com/300x200/f59e0b/ffffff?text=NBCF" alt="National Breast Cancer Foundation" />
          </div>
          <div class="resource-preview__content">
            <h3>National Breast Cancer Foundation</h3>
            <p>Early detection, education and support services for those affected by breast cancer.</p>
          </div>
        </div>

        <div class="resource-preview-card">
          <div class="resource-preview__image">
            <img src="https://via.placeholder.com/300x200/8b5cf6/ffffff?text=Susan+G.+Komen" alt="Susan G. Komen" />
          </div>
          <div class="resource-preview__content">
            <h3>Susan G. Komen</h3>
            <p>World's largest nonprofit funding source for the fight against breast cancer.</p>
          </div>
        </div>

        <div class="resource-preview-card">
          <div class="resource-preview__image">
            <img src="https://via.placeholder.com/300x200/10b981/ffffff?text=Patient+Advocate" alt="Patient Advocate Foundation" />
          </div>
          <div class="resource-preview__content">
            <h3>Patient Advocate Foundation</h3>
            <p>Direct patient services for Americans with chronic and life-threatening illnesses.</p>
          </div>
        </div>
      </div>

      <div class="text-center mt-4">
        <a href="/resources" class="btn btn--primary">View All Resources</a>
      </div>
    </div>
  </section>

  <!-- Newsletter -->
  <section class="section section--alt">
    <div class="container">
      <div class="newsletter">
        <div class="newsletter__content">
          <h2 class="newsletter__title">Stay Connected</h2>
          <p class="newsletter__text">
            Join our community for book updates, events, and resources for advocates and caregivers.
          </p>
          <form class="newsletter__form">
            <input type="email" class="newsletter__input" placeholder="Enter your email" required />
            <button type="submit" class="btn btn--primary">Subscribe</button>
          </form>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Hero Section */
  .hero {
    padding-top: 6rem;
    min-height: 100vh;
    display: flex;
    align-items: center;
    background: linear-gradient(135deg, var(--color-surface) 0%, var(--color-background) 100%);
  }

  .hero__container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .hero__badge {
    display: inline-block;
    padding: 0.375rem 1rem;
    background: var(--color-accent);
    color: white;
    border-radius: 9999px;
    font-size: 0.875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.025em;
    margin-bottom: 1.5rem;
  }

  .hero__title {
    margin-bottom: 1.5rem;
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-accent) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero__subtitle {
    font-size: 1.25rem;
    color: var(--color-text-light);
    margin-bottom: 2rem;
    line-height: 1.6;
  }

  .hero__buttons {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .hero__visual {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .hero__image {
    width: 100%;
    max-width: 450px;
    height: auto;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-xl);
  }

  /* Sections */
  .section {
    padding: 5rem 0;
  }

  .section--alt {
    background: var(--color-surface);
  }

  .section__header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .section__title {
    margin-bottom: 1rem;
  }

  .section__subtitle {
    font-size: 1.125rem;
    color: var(--color-text-light);
    max-width: 600px;
    margin: 0 auto;
  }

  /* Pre-order Section */
  .preorder {
    text-align: center;
  }

  .preorder__headline h2 {
    font-size: 2.5rem;
    color: var(--color-background);
    margin-bottom: 1.5rem;
  }

  .preorder__headline p {
    font-size: 1.2rem;
    max-width: 600px;
    margin: 0 auto 3rem;
    opacity: 0.9;
    color: rgba(255, 255, 255, 0.9);
  }

  .preorder__links {
    display: flex;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  /* Summary Section */
  .summary {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  .summary__body h2 {
    font-size: 2.5rem;
    color: var(--color-primary);
    margin-bottom: 2rem;
  }

  .summary__body p {
    font-size: 1.15rem;
    margin-bottom: 2rem;
    color: var(--color-text-light);
  }

  .summary__highlights {
    background: var(--color-surface);
    padding: 2rem;
    border-radius: var(--radius-lg);
    border-left: 4px solid var(--color-accent);
  }

  .summary__highlights h3 {
    color: var(--color-primary);
    margin-bottom: 1.5rem;
    font-size: 1.5rem;
  }

  .summary__highlights ul {
    list-style: none;
    padding: 0;
  }

  .summary__highlights li {
    padding: 0.75rem 0;
    border-bottom: 1px solid rgba(108, 117, 125, 0.1);
    position: relative;
    padding-left: 1.5rem;
  }

  .summary__highlights li::before {
    content: '→';
    position: absolute;
    left: 0;
    color: var(--color-accent);
    font-weight: bold;
  }

  .summary__highlights li:last-child {
    border-bottom: none;
  }

  /* Structure Section */
  .structure {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
  }

  .structure__card {
    background: white;
    padding: 2.5rem;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
    text-align: center;
    transition: all var(--transition-base);
    border-top: 4px solid var(--color-accent);
  }

  .structure__card:hover {
    transform: translateY(-5px);
    box-shadow: var(--shadow-lg);
  }

  .structure__card h3 {
    color: var(--color-primary);
    font-size: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .structure__card p {
    margin-bottom: 0;
    font-size: 1.1rem;
    color: var(--color-text-light);
  }

  /* Author Section */
  .author {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 4rem;
    align-items: center;
  }

  .author__portrait img {
    width: 100%;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-xl);
  }

  .author__bio h2 {
    font-size: 2.5rem;
    color: var(--color-primary);
    margin-bottom: 2rem;
  }

  .author__bio p {
    font-size: 1.1rem;
    margin-bottom: 1.5rem;
    color: var(--color-text-light);
  }

  .author__links {
    display: flex;
    gap: 1.5rem;
    margin-top: 2rem;
  }

  /* Blog Grid */
  .blog-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
  }

  .blog-card {
    background: white;
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-md);
    transition: transform var(--transition-base);
  }

  .blog-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }

  .blog-card__image {
    width: 100%;
    height: 200px;
    object-fit: cover;
  }

  .blog-card__content {
    padding: 1.5rem;
  }

  .blog-card__category {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    background: var(--color-accent);
    color: white;
    border-radius: var(--radius-sm);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
  }

  .blog-card__title {
    font-size: 1.25rem;
    margin-bottom: 0.5rem;
  }

  .blog-card__title a {
    color: var(--color-primary);
  }

  .blog-card__excerpt {
    color: var(--color-text-light);
    margin-bottom: 1rem;
  }

  .blog-card__date {
    font-size: 0.875rem;
    color: var(--color-text-lighter);
  }

  /* Testimonials */
  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
  }

  .testimonial-card {
    background: white;
    padding: 2rem;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
  }

  .testimonial-card__quote {
    font-family: var(--font-heading);
    font-size: 1.125rem;
    font-style: italic;
    color: var(--color-text);
    margin-bottom: 1.5rem;
    line-height: 1.6;
  }

  .testimonial-card__author {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .testimonial-card__avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--color-accent);
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-weight: 600;
    font-size: 0.875rem;
  }

  .testimonial-card__name {
    font-weight: 600;
    color: var(--color-primary);
    font-size: 0.95rem;
  }

  .testimonial-card__title {
    font-size: 0.875rem;
    color: var(--color-text-lighter);
  }

  /* Newsletter */
  .newsletter {
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-light) 100%);
    border-radius: var(--radius-xl);
    padding: 3rem;
    color: white;
    text-align: center;
  }

  .newsletter__title {
    color: white;
    margin-bottom: 1rem;
  }

  .newsletter__text {
    color: rgba(255, 255, 255, 0.9);
    margin-bottom: 2rem;
  }

  .newsletter__form {
    display: flex;
    gap: 1rem;
    max-width: 500px;
    margin: 0 auto;
  }

  .newsletter__input {
    flex: 1;
    padding: 0.75rem 1.25rem;
    border: none;
    border-radius: var(--radius-md);
    font-size: 1rem;
  }

  .newsletter__input:focus {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  /* Resources Preview */
  .resources-preview {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
    margin-bottom: 2rem;
  }

  .resource-preview-card {
    background: white;
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-md);
    transition: all var(--transition-base);
  }

  .resource-preview-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-xl);
  }

  .resource-preview__image {
    height: 160px;
    overflow: hidden;
  }

  .resource-preview__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-slow);
  }

  .resource-preview-card:hover .resource-preview__image img {
    transform: scale(1.05);
  }

  .resource-preview__content {
    padding: 1.5rem;
  }

  .resource-preview__content h3 {
    font-size: 1.25rem;
    color: var(--color-primary);
    margin-bottom: 0.75rem;
  }

  .resource-preview__content p {
    color: var(--color-text-light);
    font-size: 0.95rem;
    margin: 0;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .hero__container {
      grid-template-columns: 1fr;
      gap: 2rem;
      text-align: center;
    }

    .hero__buttons {
      justify-content: center;
    }

    .summary {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .author {
      grid-template-columns: 1fr;
      gap: 3rem;
      text-align: center;
    }

    .preorder__links {
      flex-direction: column;
      align-items: center;
    }

    .newsletter__form {
      flex-direction: column;
    }
  }
</style>