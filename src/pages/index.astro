---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

// Get latest blog posts
const allBlogPosts = await getCollection('blog');
const latestPosts = allBlogPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

// Get featured resources for preview
const allResources = await getCollection('resources');
const previewResources = allResources.filter(r =>
  ['nbcf', 'komen', 'patient-advocate'].includes(r.slug)
);
---

<BaseLayout title="Home">
  <!-- Hero Section -->
  <section class="hero">
    <div class="hero__background">
      <img src="/living-to-die-hero-parallax.webp" alt="" class="hero__bg-image" />
      <div class="hero__overlay"></div>
    </div>
    <div class="hero__content">
      <span class="hero__badge">Coming 2026</span>
      <h1 class="hero__title">Living to Die</h1>
      <p class="hero__subtitle">
        A powerful memoir of faith, justice, and a mother's relentless fight against medical negligence.
      </p>
      <div class="hero__buttons">
        <a href="#about" class="btn btn--primary">Discover the Story</a>
        <a href="#author" class="btn btn--secondary">Meet the Author</a>
      </div>
    </div>
  </section>

  <!-- Pre-order Section -->
  <section class="section section--contrast" id="preorder">
    <div class="container preorder">
      <div class="preorder__headline">
        <h2>Reserve Your Copy</h2>
        <p>
          Living to Die draws readers into the Sawicki family's fourteen-year-long odyssey through aggressive breast cancer, medical injustice, and the relentless pursuit of truth.
        </p>
      </div>
      <div class="preorder__links">
        <a class="btn btn--primary" href="#">Coming Soon</a>

      </div>
    </div>
  </section>

  <!-- Summary Section -->
  <section class="section" id="summary">
    <div class="container summary">
      <div class="summary__body">
        <h2>An Unconventional Journey</h2>
        <p>
          On August 8, 2000, a follow-up mammogram missed an abnormality. Ten months later, by the time her cancer was finally diagnosed, it had spread to her lymph nodes. Drawing on deep wells of faith, and raw grit, Brenda waged a fight for her life and for accountability— challenging a medical system that failed her.
        </p>
        <p>
          Through meticulous reporting and intimate storytelling, Living to Die chronicles Brenda's unconventional journey from diagnosis to her final years: refusing aggressive treatments, the legal crusade against negligence, and the fierce love that kept a family whole. This memoir bears witness to the cost of institutional failure and to the incandescent strength of a woman determined to leave a legacy of justice.
        </p>
      </div>
      <aside class="summary__highlights">
        <h3>Key Themes</h3>
        <ul>
          <li>Patient advocacy and systemic accountability</li>
          <li>Motherhood, legacy, and preparing a family for goodbye</li>
          <li>Faith as anchor through grief and uncertainty</li>
        </ul>
      </aside>
    </div>
  </section>

  <!-- Book Structure -->
  <section class="section section--muted" id="structure">
    <div class="container structure">
      <div class="structure__card">
        <h3>Inside the Book</h3>
        <p>a narrative spanning the diagnosis, trial preparation, courtroom testimony, jury misconduct, and the reverberations that followed.</p>
      </div>
      <div class="structure__card">
        <h3>For Readers Who</h3>
        <p>champion women's health,  and believe in the power of legal reform.</p>
      </div>
      <div class="structure__card">
        <h3>Ideal For</h3>
        <p>book clubs, faith communities, advocacy organizations, and graduate ethics programs.</p>
      </div>
    </div>
  </section>

  <!-- Author Section -->
  <section class="section" id="author">
    <div class="container author">
      <div class="author__portrait">
        <img src="/diane-melton.jpg" alt="Diane Melton" />
      </div>
      <div class="author__bio">
        <h2>About the Author</h2>
        <p>
          Diane Melton's devotion to storytelling began in third grade when a teacher spotlighted her writing. She later earned a Master of Arts in Liberal Studies from Wesleyan University, concentrating in creative writing, and went on to teach writing and poetry at Central Connecticut State University.
        </p>
        <p>
          Her essays and narrative nonfiction have appeared in The New York Times, The Hartford Courant, Northeast Magazine, Seasons Magazine, and Latitudes. She was honored by the Connecticut Society of Professional Journalists for outstanding feature writing.
        </p>
        <p>
          Away from the page, Diane is an avid street photographer who loves welcoming friends around the table, walking, swimming, training at the gym, and escaping to the beach. Living to Die marks her debut nonfiction book, and she invites readers to join her on Brenda Sawicki's incredible journey.
        </p>
      </div>
    </div>
  </section>

  <!-- Resources Preview -->
  <section class="section">
    <div class="container">
      <div class="section__header">
        <h2 class="section__title">Resources & Support</h2>
        <p class="section__subtitle">
          Organizations and information for those affected by medical negligence and seeking advocacy support.
        </p>
      </div>

      <div class="resources-preview">
        {previewResources.map(resource => (
          <a href={resource.data.url} target="_blank" rel="noopener" class="resource-preview-card">
            <div class="resource-preview__image">
              <img
                src={`/api/og-image?url=${encodeURIComponent(resource.data.url)}`}
                alt={resource.data.title}
                loading="lazy"
                onerror="this.src='https://images.unsplash.com/photo-1559757148-5c350d0d3c56?ixlib=rb-4.0.3&auto=format&fit=crop&w=400&h=200&q=80'"
              />
            </div>
            <div class="resource-preview__content">
              <h3>{resource.data.title}</h3>
              <p>{resource.data.description}</p>
            </div>
          </a>
        ))}
      </div>

      <div class="text-center mt-lg">
        <a href="/resources" class="btn btn--primary">View All Resources</a>
      </div>
    </div>
  </section>

  <!-- Newsletter -->
  <section class="section section--alt">
    <div class="container">
      <div class="newsletter">
        <div class="newsletter__content">
          <h2 class="newsletter__title">Stay Connected</h2>
          <p class="newsletter__text">
            Join our community for book updates, events, and resources for advocates and caregivers.
          </p>
          <form
            class="newsletter__form"
            id="homepage-newsletter-form"
            action="https://assets.mailerlite.com/jsonp/2188276/forms/181849541197170482/subscribe"
            method="POST"
          >
            <input type="hidden" name="ml-submit" value="1" />
            <input type="hidden" name="anticsrf" value="true" />
            <input
              type="email"
              name="fields[email]"
              class="newsletter__input"
              placeholder="Enter your email"
              required
              autocomplete="email"
            />
            <button type="submit" class="btn btn--primary">Subscribe</button>
          </form>
          <p class="newsletter__success" id="homepage-newsletter-success">Thanks for subscribing!</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Import new style system */
  @import '../styles/global-v2.css';

  /* Hero Section - Parallax Background */
  .hero {
    position: relative;
    min-height: 85vh;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    overflow: hidden;
  }

  .hero__background {
    position: absolute;
    inset: -20%;
    z-index: 0;
  }

  .hero__bg-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center left;
    filter: saturate(1.8) contrast(1.15) brightness(1.05);
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      270deg,
      rgba(255, 255, 255, 0.95) 0%,
      rgba(255, 255, 255, 0.85) 30%,
      rgba(255, 255, 255, 0.4) 60%,
      rgba(255, 255, 255, 0) 100%
    );
  }

  .hero__content {
    position: relative;
    z-index: 1;
    max-width: 550px;
    padding: 4rem;
    margin-left: auto;
    margin-right: 5%;
  }

  .hero__badge {
    display: inline-block;
    padding: 0.5rem 1.25rem;
    background: var(--color-rose);
    color: white;
    border-radius: var(--radius-full);
    font-family: var(--font-display);
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: var(--tracking-wider);
    margin-bottom: var(--space-lg);
  }

  .hero__title {
    font-family: var(--font-display);
    font-size: var(--text-5xl);
    font-weight: 800;
    letter-spacing: 0.05em;
    line-height: 1.0;
    text-transform: uppercase;
    color: var(--color-sage-dark);
    margin-bottom: var(--space-md);
  }

  .hero__subtitle {
    font-family: var(--font-body);
    font-size: var(--text-lg);
    color: var(--color-warm-gray);
    margin-bottom: var(--space-xl);
    line-height: var(--leading-relaxed);
    font-weight: 400;
  }

  .hero__buttons {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  /* Sections - Clean Publisher Style */
  .section {
    padding: var(--space-3xl) 0;
  }

  .section--alt {
    background: var(--color-pure-white);
  }

  .section--contrast {
    background: linear-gradient(135deg, #b8d4e3 0%, #9ac2d9 100%);
    color: var(--color-soft-black);
  }

  .section--muted {
    background: var(--color-beige);
  }

  .section__header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .section__title {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--color-sage-dark);
    margin-bottom: var(--space-md);
  }

  .section__subtitle {
    font-size: 1.125rem;
    color: var(--color-text-light);
    max-width: 600px;
    margin: 0 auto;
  }

  /* Pre-order Section */
  .preorder {
    text-align: center;
  }

  .preorder__headline h2 {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    font-weight: 700;
    color: var(--color-soft-black);
    margin-bottom: var(--space-md);
  }

  .preorder__headline p {
    font-size: 1.2rem;
    max-width: 600px;
    margin: 0 auto 3rem;
    color: var(--color-warm-gray);
  }

  .preorder__links {
    display: flex;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  /* Summary Section */
  .summary {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  .summary__body h2 {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    color: var(--color-sage-dark);
    margin-bottom: var(--space-lg);
    font-weight: 700;
  }

  .summary__body p {
    font-size: 1.15rem;
    margin-bottom: 2rem;
    color: var(--color-text-light);
  }

  .summary__highlights {
    background: var(--color-cream);
    padding: var(--space-lg);
    border-radius: var(--radius-xl);
    border-left: 4px solid var(--color-rose);
    box-shadow: var(--shadow-sm);
  }

  .summary__highlights h3 {
    color: var(--color-primary);
    margin-bottom: 1.5rem;
    font-size: 1.5rem;
  }

  .summary__highlights ul {
    list-style: none;
    padding: 0;
  }

  .summary__highlights li {
    padding: 0.75rem 0;
    border-bottom: 1px solid rgba(108, 117, 125, 0.1);
    position: relative;
    padding-left: 1.5rem;
  }

  .summary__highlights li::before {
    content: '→';
    position: absolute;
    left: 0;
    color: var(--color-accent);
    font-weight: bold;
  }

  .summary__highlights li:last-child {
    border-bottom: none;
  }

  /* Structure Section */
  .structure {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
  }

  .structure__card {
    background: var(--color-pure-white);
    padding: var(--space-xl);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-md);
    text-align: center;
    transition: all var(--transition-base);
    border-top: 3px solid var(--color-rose);
  }

  .structure__card:hover {
    transform: translateY(-5px);
    box-shadow: var(--shadow-lg);
  }

  .structure__card h3 {
    font-family: var(--font-display);
    color: var(--color-sage-dark);
    font-size: var(--text-xl);
    margin-bottom: var(--space-md);
    font-weight: 700;
  }

  .structure__card p {
    margin-bottom: 0;
    font-size: 1.1rem;
    color: var(--color-text-light);
  }

  /* Author Section */
  .author {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 4rem;
    align-items: center;
  }

  .author__portrait img {
    width: 100%;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-xl);
  }

  .author__bio h2 {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    color: var(--color-sage-dark);
    margin-bottom: var(--space-lg);
    font-weight: 700;
  }

  .author__bio p {
    font-size: 1.1rem;
    margin-bottom: 1.5rem;
    color: var(--color-text-light);
  }

  .author__links {
    display: flex;
    gap: 1.5rem;
    margin-top: 2rem;
  }

  /* Blog Grid */
  .blog-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
  }

  .blog-card {
    background: white;
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-md);
    transition: transform var(--transition-base);
  }

  .blog-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }

  .blog-card__image {
    width: 100%;
    height: 200px;
    object-fit: cover;
  }

  .blog-card__content {
    padding: 1.5rem;
  }

  .blog-card__category {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    background: var(--color-accent);
    color: white;
    border-radius: var(--radius-sm);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
  }

  .blog-card__title {
    font-size: 1.25rem;
    margin-bottom: 0.5rem;
  }

  .blog-card__title a {
    color: var(--color-primary);
  }

  .blog-card__excerpt {
    color: var(--color-text-light);
    margin-bottom: 1rem;
  }

  .blog-card__date {
    font-size: 0.875rem;
    color: var(--color-text-lighter);
  }

  /* Newsletter */
  .newsletter {
    background: var(--gradient-warm);
    border-radius: var(--radius-2xl);
    padding: var(--space-2xl);
    text-align: center;
    box-shadow: var(--shadow-lg);
  }

  .newsletter__title {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 700;
    color: var(--color-sage-dark);
    margin-bottom: var(--space-sm);
  }

  .newsletter__text {
    color: var(--color-warm-gray);
    margin-bottom: var(--space-lg);
    font-size: var(--text-base);
  }

  .newsletter__form {
    display: flex;
    gap: 1rem;
    max-width: 500px;
    margin: 0 auto;
  }

  .newsletter__input {
    flex: 1;
    padding: 0.75rem 1.25rem;
    border: none;
    border-radius: var(--radius-md);
    font-size: 1rem;
  }

  .newsletter__input:focus {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .newsletter__success {
    display: none;
    color: var(--color-accent);
    font-style: italic;
    margin-top: 1rem;
  }

  .newsletter__success.show {
    display: block;
  }

  .newsletter__form.hidden {
    display: none;
  }

  /* Resources Preview */
  .resources-preview {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
    margin-bottom: 2rem;
  }

  .resource-preview-card {
    background: white;
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-md);
    transition: all var(--transition-base);
  }

  .resource-preview-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-xl);
  }

  .resource-preview__image {
    height: 160px;
    overflow: hidden;
  }

  .resource-preview__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-slow);
  }

  .resource-preview-card:hover .resource-preview__image img {
    transform: scale(1.05);
  }

  .resource-preview__content {
    padding: 1.5rem;
  }

  .resource-preview__content h3 {
    font-size: 1.25rem;
    color: var(--color-primary);
    margin-bottom: 0.75rem;
  }

  .resource-preview__content p {
    color: var(--color-text-light);
    font-size: 0.95rem;
    margin: 0;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .hero {
      min-height: 70vh;
    }

    .hero__overlay {
      background: linear-gradient(
        180deg,
        rgba(255, 255, 255, 0.95) 0%,
        rgba(255, 255, 255, 0.85) 50%,
        rgba(255, 255, 255, 0.6) 100%
      );
    }

    .hero__content {
      margin-left: 0;
      padding: 2rem;
      text-align: center;
      max-width: 100%;
    }

    .hero__title {
      font-size: var(--text-3xl);
    }

    .hero__buttons {
      justify-content: center;
    }

    .summary {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .author {
      grid-template-columns: 1fr;
      gap: 3rem;
      text-align: center;
    }

    .preorder__links {
      flex-direction: column;
      align-items: center;
    }

    .newsletter__form {
      flex-direction: column;
    }
  }
</style>

<script>
  // Parallax effect for hero background
  const heroBg = document.querySelector('.hero__background') as HTMLElement;
  const hero = document.querySelector('.hero') as HTMLElement;

  if (heroBg && hero) {
    window.addEventListener('scroll', () => {
      const scrolled = window.pageYOffset;
      const heroHeight = hero.offsetHeight;

      if (scrolled < heroHeight) {
        const parallaxOffset = scrolled * 0.4;
        heroBg.style.transform = `translateY(${parallaxOffset}px)`;
      }
    }, { passive: true });
  }

  // Newsletter form submission
  document.getElementById('homepage-newsletter-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.target as HTMLFormElement;
    const formData = new FormData(form);
    const successEl = document.getElementById('homepage-newsletter-success');

    try {
      await fetch(form.action, {
        method: 'POST',
        body: formData,
        mode: 'no-cors'
      });

      form.classList.add('hidden');
      successEl?.classList.add('show');
    } catch (error) {
      form.submit();
    }
  });
</script>
