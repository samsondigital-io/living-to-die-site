---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getHomepageContent } from '../lib/content';

const content = await getHomepageContent();
---

<BaseLayout title="Mockup A - Nav Branding" description="Mockup A" minimalNav={false}>
  <!-- Custom nav with Diane Melton branding -->
  <nav class="mockup-nav" id="mockup-navbar">
    <div class="mockup-nav__container">
      <a href="/" class="mockup-nav__brand">Diane Melton</a>
      <ul class="mockup-nav__menu">
        <li><a href="/" class="mockup-nav__link">Home</a></li>
        <li><a href="/#author" class="mockup-nav__link">About</a></li>
        <li><a href="/resources" class="mockup-nav__link">Resources</a></li>
        <li><a href="/contact" class="mockup-nav__link">Contact</a></li>
      </ul>
    </div>
  </nav>

  <!-- Hero Section - No author line (her name is in the nav) -->
  <section class="hero">
    <div class="hero__background">
      <img src="/living-to-die-hero-parallax.webp" alt="Soft focus background image" class="hero__bg-image" />
      <div class="hero__overlay"></div>
    </div>
    <div class="hero__content">
      <span class="hero__badge">{content.hero_badge}</span>
      <h1 class="hero__title">{content.hero_title}</h1>
      <p class="hero__subtitle">
        {content.hero_subtitle}
      </p>
      <p class="hero__tagline">A Debut Memoir</p>
      <div class="hero__buttons">
        <a href="#summary" class="btn btn--primary">Discover the Story</a>
        <a href="#author" class="btn btn--secondary">Meet the Author</a>
      </div>
    </div>
  </section>

  <div class="mockup-label">
    <strong>Mockup A:</strong> "Diane Melton" as site branding in the navigation. Hero shows "A Debut Memoir" instead of "A book by Diane Melton"
  </div>
</BaseLayout>

<style>
  /* Hide the default nav */
  :global(.nav) {
    display: none !important;
  }

  .mockup-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--color-border);
    padding: 1rem 1.5rem;
  }

  .mockup-nav__container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: var(--container-max);
    margin: 0 auto;
  }

  .mockup-nav__brand {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-primary);
    letter-spacing: 0.02em;
  }

  .mockup-nav__brand:hover {
    color: var(--color-accent);
  }

  .mockup-nav__menu {
    display: flex;
    list-style: none;
    gap: 2.5rem;
    margin: 0;
    padding: 0;
  }

  .mockup-nav__link {
    color: var(--color-text);
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 1.1rem;
    letter-spacing: 0.03em;
    transition: color var(--transition-fast);
  }

  .mockup-nav__link:hover {
    color: var(--color-accent);
  }

  /* Hero styles */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    padding: var(--space-3xl);
    overflow: hidden;
  }

  .hero__background {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero__bg-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, transparent 0%, rgba(255,255,255,0.3) 50%, rgba(255,255,255,0.85) 100%);
  }

  .hero__content {
    position: relative;
    z-index: 1;
    max-width: 550px;
    text-align: left;
  }

  .hero__badge {
    display: inline-block;
    padding: var(--space-xs) var(--space-md);
    background: var(--color-primary);
    color: white;
    border-radius: var(--radius-full);
    font-family: var(--font-display);
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: var(--tracking-wider);
    margin-bottom: var(--space-lg);
  }

  .hero__title {
    font-family: var(--font-display);
    font-size: var(--text-5xl);
    font-weight: 800;
    letter-spacing: 0.05em;
    line-height: 1.0;
    text-transform: uppercase;
    color: var(--color-sage-dark);
    margin-bottom: var(--space-md);
  }

  .hero__subtitle {
    font-family: var(--font-body);
    font-size: var(--text-lg);
    color: var(--color-warm-gray);
    margin-bottom: var(--space-md);
    line-height: var(--leading-relaxed);
    font-weight: 400;
  }

  .hero__tagline {
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: var(--color-rose);
    font-style: italic;
    margin-bottom: var(--space-xl);
  }

  .hero__buttons {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .mockup-label {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    background: var(--color-soft-black);
    color: white;
    padding: 1rem 2rem;
    font-family: var(--font-body);
    font-size: 0.95rem;
    z-index: 9999;
  }

  @media (max-width: 768px) {
    .mockup-nav__menu {
      display: none;
    }
    .hero__title {
      font-size: var(--text-3xl);
    }
  }
</style>
