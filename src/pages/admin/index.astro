---
// Simple admin page - password protected
const ADMIN_PASSWORD = import.meta.env.ADMIN_PASSWORD || 'changeme';

// Check for auth cookie
const authCookie = Astro.cookies.get('admin_auth');
const isAuthenticated = authCookie?.value === 'true';

// Handle login
if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const password = formData.get('password');

  if (password === ADMIN_PASSWORD) {
    Astro.cookies.set('admin_auth', 'true', {
      path: '/',
      maxAge: 60 * 60 * 24, // 24 hours
      httpOnly: true,
      secure: true,
      sameSite: 'strict'
    });
    return Astro.redirect('/admin');
  }
}
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="robots" content="noindex, nofollow">
  <title>Admin - Living to Die</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: system-ui, -apple-system, sans-serif;
      background: #f5f5f5;
      min-height: 100vh;
      padding: 2rem;
    }
    .container { max-width: 800px; margin: 0 auto; }
    h1 { color: #333; margin-bottom: 1.5rem; }
    h2 { color: #555; margin: 2rem 0 1rem; font-size: 1.25rem; }

    .login-form {
      background: white;
      padding: 2rem;
      border-radius: 8px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.1);
      max-width: 400px;
      margin: 4rem auto;
    }
    .login-form h1 { text-align: center; }
    .login-form input {
      width: 100%;
      padding: 0.75rem;
      margin: 1rem 0;
      border: 1px solid #ddd;
      border-radius: 4px;
      font-size: 1rem;
    }
    .login-form button {
      width: 100%;
      padding: 0.75rem;
      background: #8B3A62;
      color: white;
      border: none;
      border-radius: 4px;
      font-size: 1rem;
      cursor: pointer;
    }
    .login-form button:hover { background: #6d2e4d; }

    .field { margin-bottom: 1.5rem; }
    label {
      display: block;
      font-weight: 600;
      margin-bottom: 0.5rem;
      color: #333;
    }
    input[type="text"], textarea {
      width: 100%;
      padding: 0.75rem;
      border: 1px solid #ddd;
      border-radius: 4px;
      font-size: 1rem;
      font-family: inherit;
    }
    textarea { min-height: 120px; resize: vertical; }
    input:focus, textarea:focus {
      outline: none;
      border-color: #8B3A62;
      box-shadow: 0 0 0 3px rgba(139, 58, 98, 0.1);
    }

    .section {
      background: white;
      padding: 1.5rem;
      border-radius: 8px;
      margin-bottom: 1.5rem;
      box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    }
    .section h2 { margin-top: 0; color: #8B3A62; }
    .section--preorder { background: linear-gradient(135deg, #d4e8f2 0%, #c4dce8 100%); }
    .section--newsletter { background: linear-gradient(135deg, #f5e6ec 0%, #ead4de 100%); }
    .subsection-title { color: #8B3A62; margin: 1.5rem 0 1rem; font-size: 1.1rem; border-top: 1px solid #eee; padding-top: 1.5rem; }
    .card-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1rem; }
    .card-edit { background: #f9f9f9; padding: 1rem; border-radius: 6px; border-top: 3px solid #8B3A62; }
    .card-edit textarea { min-height: 80px; }

    .save-btn {
      background: #8B3A62;
      color: white;
      border: none;
      padding: 1rem 2rem;
      font-size: 1rem;
      border-radius: 4px;
      cursor: pointer;
      margin-top: 1rem;
    }
    .save-btn:hover { background: #6d2e4d; }
    .save-btn:disabled { background: #ccc; cursor: not-allowed; }

    .status {
      padding: 1rem;
      border-radius: 4px;
      margin-top: 1rem;
      display: none;
    }
    .status.success { display: block; background: #d4edda; color: #155724; }
    .status.error { display: block; background: #f8d7da; color: #721c24; }

    .logout { float: right; color: #666; text-decoration: none; }
    .logout:hover { color: #333; }

    .header-actions {
      display: flex;
      align-items: center;
      gap: 1rem;
      margin-bottom: 1.5rem;
    }
    .header-actions h1 { margin-bottom: 0; }
    .external-link {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.5rem 1rem;
      background: #09c269;
      color: white;
      text-decoration: none;
      border-radius: 4px;
      font-size: 0.875rem;
      font-weight: 500;
    }
    .external-link:hover { background: #07a358; }
    .external-link svg { width: 16px; height: 16px; }
  </style>
</head>
<body>
  <div class="container">
    {!isAuthenticated ? (
      <div class="login-form">
        <h1>Admin Login</h1>
        <form method="POST">
          <input type="password" name="password" placeholder="Enter password" required />
          <button type="submit">Login</button>
        </form>
      </div>
    ) : (
      <>
        <a href="/admin/logout" class="logout">Logout</a>
        <div class="header-actions">
          <h1>Edit Homepage Content</h1>
          <a href="https://dashboard.mailerlite.com/" target="_blank" rel="noopener noreferrer" class="external-link">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
              <polyline points="22,6 12,13 2,6"></polyline>
            </svg>
            MailerLite
          </a>
        </div>

        <div id="status" class="status"></div>

        <form id="content-form">
          <!-- Hero Section -->
          <div class="section section--hero">
            <h2>Hero Section</h2>
            <div class="field">
              <label for="hero_badge">Badge Text</label>
              <input type="text" id="hero_badge" name="hero_badge" placeholder="Coming 2026" />
            </div>
            <div class="field">
              <label for="hero_title">Title</label>
              <input type="text" id="hero_title" name="hero_title" />
            </div>
            <div class="field">
              <label for="hero_subtitle">Subtitle</label>
              <textarea id="hero_subtitle" name="hero_subtitle"></textarea>
            </div>
          </div>

          <!-- Pre-order Section -->
          <div class="section section--preorder">
            <h2>Reserve Your Copy</h2>
            <div class="field">
              <label for="preorder_heading">Heading</label>
              <input type="text" id="preorder_heading" name="preorder_heading" />
            </div>
            <div class="field">
              <label for="preorder_text">Description</label>
              <textarea id="preorder_text" name="preorder_text"></textarea>
            </div>
          </div>

          <!-- Summary + Key Themes Section -->
          <div class="section">
            <h2>Book Summary</h2>
            <div class="field">
              <label for="summary_heading">Heading</label>
              <input type="text" id="summary_heading" name="summary_heading" />
            </div>
            <div class="field">
              <label for="summary_paragraph1">First Paragraph</label>
              <textarea id="summary_paragraph1" name="summary_paragraph1"></textarea>
            </div>
            <div class="field">
              <label for="summary_paragraph2">Second Paragraph</label>
              <textarea id="summary_paragraph2" name="summary_paragraph2"></textarea>
            </div>
            <h3 class="subsection-title">Key Themes</h3>
            <div class="field">
              <label for="theme1">Theme 1</label>
              <input type="text" id="theme1" name="theme1" />
            </div>
            <div class="field">
              <label for="theme2">Theme 2</label>
              <input type="text" id="theme2" name="theme2" />
            </div>
            <div class="field">
              <label for="theme3">Theme 3</label>
              <input type="text" id="theme3" name="theme3" />
            </div>
          </div>

          <!-- Book Structure Cards -->
          <div class="section section--cards">
            <h2>Book Structure Cards</h2>
            <div class="card-grid">
              <div class="card-edit">
                <div class="field">
                  <label for="structure1_heading">Card 1 Heading</label>
                  <input type="text" id="structure1_heading" name="structure1_heading" />
                </div>
                <div class="field">
                  <label for="structure1_text">Card 1 Text</label>
                  <textarea id="structure1_text" name="structure1_text"></textarea>
                </div>
              </div>
              <div class="card-edit">
                <div class="field">
                  <label for="structure2_heading">Card 2 Heading</label>
                  <input type="text" id="structure2_heading" name="structure2_heading" />
                </div>
                <div class="field">
                  <label for="structure2_text">Card 2 Text</label>
                  <textarea id="structure2_text" name="structure2_text"></textarea>
                </div>
              </div>
              <div class="card-edit">
                <div class="field">
                  <label for="structure3_heading">Card 3 Heading</label>
                  <input type="text" id="structure3_heading" name="structure3_heading" />
                </div>
                <div class="field">
                  <label for="structure3_text">Card 3 Text</label>
                  <textarea id="structure3_text" name="structure3_text"></textarea>
                </div>
              </div>
            </div>
          </div>

          <!-- Author Section -->
          <div class="section">
            <h2>About the Author</h2>
            <div class="field">
              <label for="author_bio1">Bio Paragraph 1</label>
              <textarea id="author_bio1" name="author_bio1"></textarea>
            </div>
            <div class="field">
              <label for="author_bio2">Bio Paragraph 2</label>
              <textarea id="author_bio2" name="author_bio2"></textarea>
            </div>
            <div class="field">
              <label for="author_bio3">Bio Paragraph 3</label>
              <textarea id="author_bio3" name="author_bio3"></textarea>
            </div>
          </div>

          <!-- Newsletter Section -->
          <div class="section section--newsletter">
            <h2>Newsletter Section</h2>
            <div class="field">
              <label for="newsletter_heading">Heading</label>
              <input type="text" id="newsletter_heading" name="newsletter_heading" />
            </div>
            <div class="field">
              <label for="newsletter_text">Description</label>
              <textarea id="newsletter_text" name="newsletter_text"></textarea>
            </div>
          </div>

          <button type="submit" class="save-btn" id="save-btn">Save Changes</button>
        </form>
      </>
    )}
  </div>

  {isAuthenticated && (
    <script>
      const form = document.getElementById('content-form');
      const status = document.getElementById('status');
      const saveBtn = document.getElementById('save-btn');

      // Load existing content
      async function loadContent() {
        try {
          const res = await fetch('/api/content', { credentials: 'same-origin' });
          if (res.ok) {
            const data = await res.json();
            Object.keys(data).forEach(key => {
              const input = document.getElementById(key);
              if (input) input.value = data[key] || '';
            });
          }
        } catch (e) {
          console.error('Failed to load content:', e);
        }
      }

      loadContent();

      // Save content
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        saveBtn.disabled = true;
        saveBtn.textContent = 'Saving...';

        const formData = new FormData(form);
        const data = Object.fromEntries(formData.entries());

        try {
          const res = await fetch('/api/content', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data),
            credentials: 'same-origin'
          });

          if (res.ok) {
            status.className = 'status success';
            status.textContent = 'Changes saved! The site will update in a few seconds.';
          } else {
            throw new Error('Save failed');
          }
        } catch (e) {
          status.className = 'status error';
          status.textContent = 'Failed to save. Please try again.';
        }

        saveBtn.disabled = false;
        saveBtn.textContent = 'Save Changes';

        setTimeout(() => { status.className = 'status'; }, 5000);
      });
    </script>
  )}
</body>
</html>
