---
import { type CollectionEntry, getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: post,
  }));
}
type Props = CollectionEntry<'blog'>;

const post = Astro.props;
const { Content } = await post.render();

// Get related posts
const allPosts = await getCollection('blog');
const relatedPosts = allPosts
  .filter(p => p.slug !== post.slug && p.data.category === post.data.category)
  .slice(0, 3);
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  image={post.data.heroImage}
>
  <meta slot="head" name="robots" content="noindex, nofollow" />
  <article class="blog-post">
    {post.data.heroImage && (
      <div class="post-hero">
        <img src={post.data.heroImage} alt={post.data.title} />
      </div>
    )}

    <div class="container">
      <header class="post-header">
        <div class="post-meta">
          <span class="category-badge category-badge--{post.data.category}">
            {post.data.category}
          </span>
          <time>
            {new Date(post.data.pubDate).toLocaleDateString('en-US', {
              year: 'numeric',
              month: 'long',
              day: 'numeric'
            })}
          </time>
        </div>

        <h1 class="post-title">{post.data.title}</h1>

        <p class="post-description">{post.data.description}</p>

        <div class="post-author">
          <span>By {post.data.author}</span>
          {post.data.updatedDate && (
            <span class="updated">
              Updated: {new Date(post.data.updatedDate).toLocaleDateString('en-US', {
                year: 'numeric',
                month: 'short',
                day: 'numeric'
              })}
            </span>
          )}
        </div>
      </header>

      <div class="post-content">
        <Content />
      </div>

      <footer class="post-footer">
        {post.data.tags && post.data.tags.length > 0 && (
          <div class="post-tags">
            <span>Tags:</span>
            {post.data.tags.map(tag => (
              <a href={`/blog/tag/${tag}`} class="tag">
                #{tag}
              </a>
            ))}
          </div>
        )}

        <div class="share-section">
          <h3>Share this post</h3>
          <div class="share-buttons">
            <a
              href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(post.data.title)}&url=${encodeURIComponent(Astro.url.href)}`}
              target="_blank"
              rel="noopener noreferrer"
              class="share-button share-button--twitter"
            >
              Twitter
            </a>
            <a
              href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(Astro.url.href)}`}
              target="_blank"
              rel="noopener noreferrer"
              class="share-button share-button--facebook"
            >
              Facebook
            </a>
            <a
              href={`https://www.linkedin.com/shareArticle?mini=true&url=${encodeURIComponent(Astro.url.href)}&title=${encodeURIComponent(post.data.title)}`}
              target="_blank"
              rel="noopener noreferrer"
              class="share-button share-button--linkedin"
            >
              LinkedIn
            </a>
          </div>
        </div>
      </footer>

      {relatedPosts.length > 0 && (
        <section class="related-posts">
          <h2>Related Posts</h2>
          <div class="related-grid">
            {relatedPosts.map(relPost => (
              <article class="related-card">
                {relPost.data.heroImage && (
                  <img
                    src={relPost.data.heroImage}
                    alt={relPost.data.title}
                    class="related-card__image"
                  />
                )}
                <div class="related-card__content">
                  <h3 class="related-card__title">
                    <a href={`/blog/${relPost.slug}`}>{relPost.data.title}</a>
                  </h3>
                  <p class="related-card__excerpt">{relPost.data.description}</p>
                  <time class="related-card__date">
                    {new Date(relPost.data.pubDate).toLocaleDateString('en-US', {
                      year: 'numeric',
                      month: 'short',
                      day: 'numeric'
                    })}
                  </time>
                </div>
              </article>
            ))}
          </div>
        </section>
      )}

      <div class="navigation">
        <a href="/blog" class="btn btn--secondary">← Back to Blog</a>
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .blog-post {
    padding-top: 5rem;
    padding-bottom: 5rem;
  }

  .post-hero {
    width: 100%;
    height: 400px;
    overflow: hidden;
    margin-bottom: 3rem;
  }

  .post-hero img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .post-header {
    max-width: 800px;
    margin: 0 auto 3rem;
    text-align: center;
  }

  .post-meta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .category-badge {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    background: var(--color-accent);
    color: white;
    border-radius: var(--radius-sm);
    font-size: 0.875rem;
    font-weight: 600;
    text-transform: uppercase;
  }

  .category-badge--news { background: #3b82f6; }
  .category-badge--reflections { background: #8b5cf6; }
  .category-badge--updates { background: #10b981; }
  .category-badge--events { background: #f59e0b; }

  .post-title {
    font-size: clamp(2rem, 4vw, 3rem);
    margin-bottom: 1rem;
  }

  .post-description {
    font-size: 1.25rem;
    color: var(--color-text-light);
    line-height: 1.6;
    margin-bottom: 1.5rem;
  }

  .post-author {
    color: var(--color-text-lighter);
    font-size: 0.95rem;
  }

  .post-author .updated {
    margin-left: 1rem;
    padding-left: 1rem;
    border-left: 1px solid var(--color-border);
  }

  /* Post Content */
  .post-content {
    max-width: 800px;
    margin: 0 auto 3rem;
    font-size: 1.125rem;
    line-height: 1.8;
  }

  .post-content :global(h2) {
    margin-top: 3rem;
    margin-bottom: 1.5rem;
    font-size: 2rem;
  }

  .post-content :global(h3) {
    margin-top: 2rem;
    margin-bottom: 1rem;
    font-size: 1.5rem;
  }

  .post-content :global(p) {
    margin-bottom: 1.5rem;
  }

  .post-content :global(ul),
  .post-content :global(ol) {
    margin-bottom: 1.5rem;
    padding-left: 2rem;
  }

  .post-content :global(li) {
    margin-bottom: 0.5rem;
  }

  .post-content :global(blockquote) {
    margin: 2rem 0;
    padding: 1.5rem;
    background: var(--color-surface);
    border-left: 4px solid var(--color-accent);
    font-style: italic;
  }

  .post-content :global(pre) {
    background: var(--color-surface-dark);
    padding: 1.5rem;
    border-radius: var(--radius-md);
    overflow-x: auto;
    margin: 2rem 0;
  }

  .post-content :global(code) {
    background: var(--color-surface);
    padding: 0.125rem 0.375rem;
    border-radius: var(--radius-sm);
    font-size: 0.9em;
  }

  .post-content :global(pre code) {
    background: none;
    padding: 0;
  }

  .post-content :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: var(--radius-lg);
    margin: 2rem 0;
  }

  .post-content :global(a) {
    color: var(--color-accent);
    text-decoration: underline;
  }

  .post-content :global(a:hover) {
    color: var(--color-accent-dark);
  }

  /* Post Footer */
  .post-footer {
    max-width: 800px;
    margin: 3rem auto;
    padding: 2rem 0;
    border-top: 1px solid var(--color-border);
  }

  .post-tags {
    margin-bottom: 2rem;
  }

  .post-tags span {
    margin-right: 1rem;
    font-weight: 600;
  }

  .tag {
    display: inline-block;
    padding: 0.375rem 0.75rem;
    margin: 0.25rem;
    background: var(--color-surface);
    border-radius: var(--radius-sm);
    color: var(--color-text);
    text-decoration: none;
    transition: all var(--transition-fast);
  }

  .tag:hover {
    background: var(--color-accent);
    color: white;
  }

  /* Share Section */
  .share-section h3 {
    font-size: 1.25rem;
    margin-bottom: 1rem;
  }

  .share-buttons {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .share-button {
    padding: 0.5rem 1rem;
    border-radius: var(--radius-sm);
    color: white;
    text-decoration: none;
    font-weight: 600;
    transition: transform var(--transition-fast);
  }

  .share-button:hover {
    transform: scale(1.05);
  }

  .share-button--twitter { background: #1da1f2; }
  .share-button--facebook { background: #1877f2; }
  .share-button--linkedin { background: #0077b5; }

  /* Related Posts */
  .related-posts {
    margin: 4rem 0;
  }

  .related-posts h2 {
    margin-bottom: 2rem;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
  }

  .related-card {
    background: white;
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-md);
    transition: transform var(--transition-base);
  }

  .related-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }

  .related-card__image {
    width: 100%;
    height: 150px;
    object-fit: cover;
  }

  .related-card__content {
    padding: 1.5rem;
  }

  .related-card__title {
    font-size: 1.25rem;
    margin-bottom: 0.5rem;
  }

  .related-card__title a {
    color: var(--color-primary);
    text-decoration: none;
  }

  .related-card__title a:hover {
    color: var(--color-accent);
  }

  .related-card__excerpt {
    color: var(--color-text-light);
    margin-bottom: 1rem;
  }

  .related-card__date {
    font-size: 0.875rem;
    color: var(--color-text-lighter);
  }

  .navigation {
    text-align: center;
    margin-top: 3rem;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .post-hero {
      height: 250px;
    }

    .post-content {
      font-size: 1rem;
    }

    .share-buttons {
      flex-direction: column;
    }

    .share-button {
      text-align: center;
    }
  }
</style>