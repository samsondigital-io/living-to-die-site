---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getHomepageContent } from '../lib/content';

const content = await getHomepageContent();
---

<BaseLayout title="Mockup B - Softer Text" description="Mockup B" minimalNav={true}>
  <!-- Hero Section with softer author text -->
  <section class="hero">
    <div class="hero__background">
      <img src="/living-to-die-hero-parallax.webp" alt="Soft focus background image" class="hero__bg-image" />
      <div class="hero__overlay"></div>
    </div>
    <div class="hero__content">
      <span class="hero__badge">{content.hero_badge}</span>
      <h1 class="hero__title">{content.hero_title}</h1>
      <p class="hero__subtitle">
        {content.hero_subtitle}
      </p>
      <p class="hero__author">By Diane Melton</p>
      <div class="hero__buttons">
        <a href="#summary" class="btn btn--primary">Discover the Story</a>
        <a href="#author" class="btn btn--secondary">Meet the Author</a>
      </div>
    </div>
  </section>

  <div class="mockup-label">
    <strong>Mockup B:</strong> Simplified to just "By Diane Melton" — cleaner, like a book cover credit
  </div>
</BaseLayout>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    padding: var(--space-3xl);
    overflow: hidden;
  }

  .hero__background {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero__bg-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, transparent 0%, rgba(255,255,255,0.3) 50%, rgba(255,255,255,0.85) 100%);
  }

  .hero__content {
    position: relative;
    z-index: 1;
    max-width: 550px;
    text-align: left;
  }

  .hero__badge {
    display: inline-block;
    padding: var(--space-xs) var(--space-md);
    background: var(--color-primary);
    color: white;
    border-radius: var(--radius-full);
    font-family: var(--font-display);
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: var(--tracking-wider);
    margin-bottom: var(--space-lg);
  }

  .hero__title {
    font-family: var(--font-display);
    font-size: var(--text-5xl);
    font-weight: 800;
    letter-spacing: 0.05em;
    line-height: 1.0;
    text-transform: uppercase;
    color: var(--color-sage-dark);
    margin-bottom: var(--space-md);
  }

  .hero__subtitle {
    font-family: var(--font-body);
    font-size: var(--text-lg);
    color: var(--color-warm-gray);
    margin-bottom: var(--space-md);
    line-height: var(--leading-relaxed);
    font-weight: 400;
  }

  .hero__author {
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: var(--color-rose);
    font-style: italic;
    margin-bottom: var(--space-xl);
  }

  .hero__buttons {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .mockup-label {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    background: var(--color-soft-black);
    color: white;
    padding: 1rem 2rem;
    font-family: var(--font-body);
    font-size: 0.95rem;
    z-index: 9999;
  }

  @media (max-width: 768px) {
    .hero__title {
      font-size: var(--text-3xl);
    }
  }
</style>
