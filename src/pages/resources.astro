---
import BaseLayout from '../layouts/BaseLayout.astro';
import ResourceCard from '../components/ResourceCard.astro';
import { getCollection } from 'astro:content';
import { listResources, type Resource, type ResourceCategory } from '../lib/resources';

// Unified resource type for display
interface DisplayResource {
  title: string;
  description: string;
  url: string;
  category: ResourceCategory;
  imageUrl?: string;
}

// Try to fetch from Redis first, fall back to content collection
let resources: DisplayResource[] = [];

try {
  const redisResources = await listResources();
  if (redisResources.length > 0) {
    // Use Redis resources
    resources = redisResources.map(r => ({
      title: r.title,
      description: r.description,
      url: r.url,
      category: r.category,
      imageUrl: r.imageUrl,
    }));
  }
} catch (error) {
  // Redis not available or error, will fall back to content collection
  console.error('Error fetching from Redis, falling back to content collection:', error);
}

// If no Redis resources, fall back to content collection
if (resources.length === 0) {
  const contentResources = await getCollection('resources');
  resources = contentResources.map(r => ({
    title: r.data.title,
    description: r.data.description,
    url: r.data.url,
    category: r.data.category as ResourceCategory,
    imageUrl: undefined,
  }));
}

// Group resources by category
const categorizedResources = {
  'medical-advocacy': resources.filter(r => r.category === 'medical-advocacy'),
  'legal-resources': resources.filter(r => r.category === 'legal-resources'),
  'medical-research': resources.filter(r => r.category === 'medical-research'),
  'support-communities': resources.filter(r => r.category === 'support-communities'),
};

const categoryTitles = {
  'medical-advocacy': 'Medical Advocacy Organizations',
  'legal-resources': 'Legal Resources & Patient Rights',
  'medical-research': 'Medical Research & Information',
  'support-communities': 'Support Communities',
};
---

<BaseLayout title="Resources & Support" description="Support resources for medical negligence, patient advocacy, and breast cancer awareness. Curated by Diane Melton, author of Living To Die.">
  <section class="resources-hero">
    <div class="container">
      <h1>Resources & Support</h1>
    
    </div>
  </section>

  {Object.entries(categorizedResources).map(([category, categoryResources]) =>
    categoryResources.length > 0 && (
      <section id={category} class={`section ${category === 'legal-resources' || category === 'support-communities' ? 'section--alt' : ''}`}>
        <div class="container">
          <h2 class="section-title">{categoryTitles[category]}</h2>
          <div class="resource-grid">
            {categoryResources.map(resource => (
              <ResourceCard
                title={resource.title}
                description={resource.description}
                url={resource.url}
                imageUrl={resource.imageUrl}
              />
            ))}
          </div>
        </div>
      </section>
    )
  )}

  <!-- Newsletter -->
  <section class="section">
    <div class="container">
      <div class="newsletter">
        <div class="newsletter__content">
          <h2 class="newsletter__title">Stay Informed</h2>
          <p class="newsletter__text">
            Subscribe to receive updates about advocacy efforts, new resources, and important developments in patient rights.
          </p>
          <form class="newsletter__form">
            <input type="email" class="newsletter__input" placeholder="Enter your email" required />
            <button type="submit" class="btn btn--primary">Subscribe</button>
          </form>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .resources-hero {
    padding: 8rem 0 4rem;
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-light) 100%);
    color: white;
    text-align: center;
  }

  .resources-hero h1 {
    color: white;
    margin-bottom: 1rem;
  }

  .resources-hero p {
    font-size: 1.25rem;
    color: rgba(255, 255, 255, 0.9);
    max-width: 700px;
    margin: 0 auto;
  }

  .section {
    padding: 5rem 0;
  }

  .section--alt {
    background: var(--color-surface);
  }

  .section-title {
    font-size: 2.5rem;
    margin-bottom: 3rem;
    color: var(--color-primary);
    text-align: center;
    font-family: var(--font-heading);
  }

  .resource-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
    gap: 2rem;
  }

  /* Newsletter */
  .newsletter {
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-light) 100%);
    border-radius: var(--radius-xl);
    padding: 3rem;
    color: white;
    text-align: center;
  }

  .newsletter__title {
    color: white;
    margin-bottom: 1rem;
  }

  .newsletter__text {
    color: rgba(255, 255, 255, 0.9);
    margin-bottom: 2rem;
    font-size: 1.125rem;
  }

  .newsletter__form {
    display: flex;
    gap: 1rem;
    max-width: 500px;
    margin: 0 auto;
  }

  .newsletter__input {
    flex: 1;
    padding: 0.75rem 1.25rem;
    border: none;
    border-radius: var(--radius-md);
    font-size: 1rem;
  }

  .newsletter__input:focus {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .resource-grid {
      grid-template-columns: 1fr;
    }

    .resource-card__actions {
      flex-direction: column;
    }

    .newsletter__form {
      flex-direction: column;
    }

    .section-title {
      font-size: 2rem;
    }
  }

  @media (max-width: 480px) {
    .resource-card__content {
      padding: 1.5rem;
    }

    .newsletter {
      padding: 2rem;
    }
  }
</style>
